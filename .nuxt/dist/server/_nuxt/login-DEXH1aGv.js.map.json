{"file":"login-DEXH1aGv.js","mappings":";;;;;;;;;;;;;;;;;;;;;;AA8KkB,iBAAA;AAClB,UAAM,UAAU,CAAC,cAAc,iBAAiB,iBAAiB,YAAY;AAC7E,UAAM,OAAO,SAAS,EAAE,OAAO,IAAI,UAAU,IAAI;AACjD,UAAM,SAAS,SAAS,EAAE,OAAO,IAAI,UAAU,IAAI;AACnD,UAAM,eAAe,IAAI,KAAK;AAC9B,UAAM,aAAa,IAAI,KAAK;AAC5B,UAAM,cAAc,IAAI,EAAE;AAC1B,UAAM,cAAc,IAAI,EAAE;AAC1B,UAAM,YAAY,IAAI,KAAK;;;AArLpB,YAAA,OAAAA,eAAAC,WAAA,EAAA,OAAM,yGAAqG,MAAA,CAAA,CAAA,iRAAA;;QAI9F,IAAG;AAAA,QAAI,OAAM;AAAA,MAAA;yBAAvB,CAEW,GAAAC,QAAAC,UAAA,aAAA;;0BADHC,cAAA,OAAKC,MAAA,OAAA,CAAO;;;cAAlBC,YAAkF,OAAA;AAAA,gBAA5E,KAAKD,MAAA,OAAA;AAAA,gBAAS,KAAI;AAAA,gBAAa,OAAM;AAAA,cAAA;;;;;;;oBAcf,SAAO,CAAzB,QAAQ,UAAK;uDAGH,QAAK,MAAA,EAAA,GAAA,sIAAA,CAAA,0EAEiC,MAAM;;AAItD,YAAA,+RAAAD,cAAA,OAAKC,MAAA,OAAA,CAAO,CAAA,kSAAA;AAUT,YAAAE,mBAAAF,MAAA,WAAA,GAAA,EAAA,OAAM,0BAAA,GAAyB,MAAA,OAAA,CAAA;;AAclC,YAAAE,mBAAAF,MAAA,IAAA,GAAA,EAAA,OAAM,kEAAA,GAAiE,MAAA,OAAA,CAAA;qBAElED,cAAA,SAAAC,MAAA,IAAA,EAAK,KAAK,qFAMmBG,eAAA,CAAA,EAAA,4BAAAH,MAAA,MAAA,EAAO,SAAK,mBAAA,CAAA;AAI7C,UAAAA,MAAA,MAAA,EAAO,OAAK;AAA4C,cAAA,6CAAAI,eAAAJ,MAAA,MAAA,EAAO,KAAK,CAAA,MAAA;AAAA;;;;AAMrE,YAAAE,mBAAAF,MAAA,IAAA,GAAA,EAAA,OAAM,kEAAA,GAAiE,MAAA,OAAA,CAAA;2CAGpEA,MAAA,YAAA,IAAY,SAAA,YADVA,MAAA,IAAA,EAAK,UAAQ,IAAA,IACrBD,cAAA,QAAMC,MAAA,YAAA,IAAY,SAAA,UAAA,kFAKmBG,eAAA,CAAA,EAAA,4BAAAH,MAAA,MAAA,EAAO,SAAA,GAAQ,yBAAA,CAAA;WAIzCA,MAAA,YAAA,GAAY;AAAE,cAAAE,mBAAAF,MAAA,GAAA,GAAA,EAAA,OAAM,yBAAA,GAAwB,MAAA,OAAA,CAAA;AAAA;AACzC,cAAAE,mBAAAF,MAAA,MAAA,GAAA,EAAA,OAAM,yBAAA,GAAwB,MAAA,OAAA,CAAA;AAAA;;AAGxC,UAAAA,MAAA,MAAA,EAAO,UAAQ;AAA4C,cAAA,6CAAAI,eAAAJ,MAAA,MAAA,EAAO,QAAQ,CAAA,MAAA;AAAA;;;;AAe/E,YAAAE,mBAAAF,MAAA,IAAA,GAAA,EAAA,OAAM,8CAAA,GAA6C,MAAA,OAAA,CAAA;;;QAQ/C,IAAG;AAAA,QAAY,OAAM;AAAA,MAAA;yBAA/B,CAAyF,GAAAH,QAAAC,UAAA,aAAA;;;;;8BAAlB,SAAO;AAAA,YAAA;AAAA;;;;;+BA0BtF,CA8BWD,WAAA;YA5BIG,MAAA,UAAA,GAAU;;;;;YAGTA,MAAA,UAAA,GAAU;;AAMZH,iBAAAK,mBAAAF,MAAA,IAAA,GAAA,EAAA,OAAM,kEAAA,GAAiE,MAAA,OAAA,CAAA;iDAElEA,MAAA,WAAA,CAAW,gHAKkBA,MAAA,WAAA,EAAA,GAAW,mBAAA,CAAA;cAI5CA,MAAA,WAAA,GAAW;+EAA4CA,MAAA,WAAA,CAAW,CAAA,MAAA;AAAA;;;;cAGhEA,MAAA,SAAA,GAAS;+HACQA,MAAA,WAAA,CAAW,CAAA,QAAA;AAAA;;;;;;;;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_push","_parent","_ssrRenderAttr","_unref","_createVNode","_ssrRenderComponent","_ssrRenderClass","_ssrInterpolate"],"sources":["../../../../pages/login.vue"],"sourcesContent":["<template>\n  <div class=\"min-h-dvh bg-white lg:flex lg:items-center lg:justify-center lg:bg-sber-gray-light lg:px-6 lg:py-10\">\n    <div class=\"w-full overflow-hidden lg:grid lg:max-w-5xl lg:grid-cols-[1.05fr_0.95fr] lg:rounded-[32px] lg:bg-white lg:shadow-xl\">\n      <div class=\"hidden lg:flex lg:flex-col lg:justify-between lg:border-r lg:border-sber-gray-light lg:bg-white lg:p-10 lg:text-sber-black\">\n        <div>\n          <NuxtLink to=\"/\" class=\"inline-flex\">\n            <img :src=\"logoUrl\" alt=\"Otter logo\" class=\"h-11 w-11 rounded-2xl brightness-0\" />\n          </NuxtLink>\n          <h1 class=\"mt-6 text-4xl font-bold leading-tight text-sber-black\">Пару кликов, и задача готова. Ничего лишнего.</h1>\n          <p class=\"mt-4 max-w-md text-sm leading-7 text-sber-gray\">\n            Теперь еще удобнее для обзора задач, календаря и планов на день.\n          </p>\n        </div>\n\n        <div class=\"rounded-[28px] bg-sber-gray-light p-5\">\n          <p class=\"text-xs uppercase tracking-[0.2em] text-sber-gray\">Что внутри</p>\n          <div class=\"relative mt-4 grid grid-cols-2 items-start gap-3\">\n            <div class=\"pointer-events-none absolute left-1/2 top-3 z-0 h-[calc(100%-1.5rem)] w-2.5 -translate-x-1/2 rounded-full bg-sber-gray-light/80\" />\n            <div class=\"pointer-events-none absolute left-3 top-1/2 z-0 h-2.5 w-[calc(100%-1.5rem)] -translate-y-1/2 rounded-full bg-sber-gray-light/80\" />\n            <div\n              v-for=\"(metric, index) in metrics\"\n              :key=\"metric\"\n              class=\"relative z-10 flex min-h-[108px] items-center justify-center rounded-2xl bg-white/95 px-4 py-4 text-center text-sber-black shadow-sm\"\n              :class=\"{ 'mt-7': index % 2 === 1 }\"\n            >\n              <p class=\"text-sm font-bold uppercase tracking-wide\">{{ metric }}</p>\n            </div>\n            <div class=\"pointer-events-none absolute left-1/2 top-1/2 z-20 flex h-24 w-24 -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-full bg-sber-gray-light/95\">\n              <div class=\"flex h-[60px] w-[60px] items-center justify-center rounded-full bg-white shadow-sm\">\n                <img :src=\"logoUrl\" alt=\"Otter logo\" class=\"h-8 w-8 brightness-0\" />\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"min-h-dvh bg-white lg:min-h-0\">\n        <div class=\"flex items-center px-4 pt-14 pb-4 lg:px-8 lg:pt-8\">\n          <button class=\"flex h-10 w-10 items-center justify-center rounded-full bg-sber-gray-light\" type=\"button\" @click=\"$router.back()\">\n            <ChevronLeft class=\"h-5 w-5 text-sber-black\" />\n          </button>\n          <h1 class=\"ml-3 text-xl font-bold text-sber-black\">Войти</h1>\n        </div>\n\n        <div class=\"flex-1 px-6 pt-6 pb-10 lg:px-8\">\n          <p class=\"mb-8 text-sm leading-relaxed text-sber-gray\">\n            Введите данные вашей учётной записи для входа в Otter\n          </p>\n\n          <form class=\"space-y-4\" @submit.prevent=\"handleLogin\">\n            <div>\n              <label class=\"mb-2 block text-sm font-medium text-sber-gray\">Email</label>\n              <div class=\"relative\">\n                <Mail class=\"absolute left-4 top-1/2 h-5 w-5 -translate-y-1/2 text-sber-gray\" />\n                <input\n                  v-model=\"form.email\"\n                  type=\"email\"\n                  placeholder=\"example@mail.ru\"\n                  autocomplete=\"email\"\n                  required\n                  class=\"input-field pl-12\"\n                  :class=\"{ 'border-red-400 bg-red-50': errors.email }\"\n                  @input=\"clearError('email')\"\n                />\n              </div>\n              <p v-if=\"errors.email\" class=\"mt-1 ml-1 text-xs text-red-500\">{{ errors.email }}</p>\n            </div>\n\n            <div>\n              <label class=\"mb-2 block text-sm font-medium text-sber-gray\">Пароль</label>\n              <div class=\"relative\">\n                <Lock class=\"absolute left-4 top-1/2 h-5 w-5 -translate-y-1/2 text-sber-gray\" />\n                <input\n                  v-model=\"form.password\"\n                  :type=\"showPassword ? 'text' : 'password'\"\n                  placeholder=\"Введите пароль\"\n                  autocomplete=\"current-password\"\n                  required\n                  class=\"input-field pl-12 pr-12\"\n                  :class=\"{ 'border-red-400 bg-red-50': errors.password }\"\n                  @input=\"clearError('password')\"\n                />\n                <button class=\"absolute right-4 top-1/2 -translate-y-1/2\" type=\"button\" @click=\"showPassword = !showPassword\">\n                  <Eye v-if=\"!showPassword\" class=\"h-5 w-5 text-sber-gray\" />\n                  <EyeOff v-else class=\"h-5 w-5 text-sber-gray\" />\n                </button>\n              </div>\n              <p v-if=\"errors.password\" class=\"mt-1 ml-1 text-xs text-red-500\">{{ errors.password }}</p>\n            </div>\n\n            <div class=\"flex justify-end\">\n              <button class=\"text-sm font-medium text-sber-green\" type=\"button\" @click=\"showForgot = true\">\n                Забыли пароль?\n              </button>\n            </div>\n\n            <button class=\"btn-primary mx-auto block w-full max-w-[320px]\" type=\"submit\">\n              Войти\n            </button>\n          </form>\n\n          <div class=\"mt-4 flex items-start gap-2 rounded-2xl bg-sber-blue-light px-4 py-3\">\n            <Info class=\"mt-0.5 h-4 w-4 flex-shrink-0 text-sber-blue\" />\n            <p class=\"text-xs text-sber-blue\">\n              Тестовый вход: введите любой email и пароль\n            </p>\n          </div>\n\n          <div class=\"my-6 text-center\">\n            <span class=\"text-sm text-sber-gray\">Нет аккаунта? </span>\n            <NuxtLink to=\"/register\" class=\"text-sm font-semibold text-sber-green\">Создать</NuxtLink>\n          </div>\n\n          <div class=\"mb-6 flex items-center gap-4\">\n            <div class=\"h-px flex-1 bg-sber-gray-mid\" />\n            <span class=\"text-sm text-sber-gray\">или</span>\n            <div class=\"h-px flex-1 bg-sber-gray-mid\" />\n          </div>\n\n          <button\n            class=\"mx-auto flex w-full max-w-[320px] items-center justify-center gap-3 rounded-2xl border border-sber-gray-mid bg-white py-4 font-semibold text-sber-black transition-colors active:bg-sber-gray-light\"\n            type=\"button\"\n            @click=\"loginWithGoogle\"\n          >\n            <svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\">\n              <path d=\"M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z\" fill=\"#4285F4\"/>\n              <path d=\"M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z\" fill=\"#34A853\"/>\n              <path d=\"M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z\" fill=\"#FBBC05\"/>\n              <path d=\"M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z\" fill=\"#EA4335\"/>\n            </svg>\n            Войти через Google\n          </button>\n        </div>\n      </div>\n    </div>\n\n    <Teleport to=\"body\">\n      <Transition name=\"overlay\">\n        <div v-if=\"showForgot\" class=\"overlay\" @click=\"closeForgotModal\" />\n      </Transition>\n      <Transition name=\"modal\">\n        <form v-if=\"showForgot\" class=\"app-modal px-6 py-6\" @click.stop @submit.prevent=\"sendReset\">\n          <h3 class=\"mb-2 text-lg font-bold text-sber-black\">Восстановление пароля</h3>\n          <p class=\"mb-4 text-sm text-sber-gray\">\n            Введите ваш email, и мы отправим ссылку для сброса пароля\n          </p>\n          <div class=\"relative mb-2\">\n            <Mail class=\"absolute left-4 top-1/2 h-5 w-5 -translate-y-1/2 text-sber-gray\" />\n            <input\n              v-model=\"forgotEmail\"\n              type=\"email\"\n              placeholder=\"Email\"\n              autocomplete=\"email\"\n              class=\"input-field pl-12\"\n              :class=\"{ 'border-red-400 bg-red-50': forgotError }\"\n              @input=\"forgotError = ''\"\n            />\n          </div>\n          <p v-if=\"forgotError\" class=\"mb-3 ml-1 text-xs text-red-500\">{{ forgotError }}</p>\n          <button class=\"btn-primary\" type=\"submit\">Отправить</button>\n          <button class=\"btn-secondary mt-3\" type=\"button\" @click=\"closeForgotModal\">Отмена</button>\n          <div v-if=\"resetSent\" class=\"mt-3 text-center text-sm font-medium text-sber-green\">\n            ✓ Письмо отправлено на {{ forgotEmail }}\n          </div>\n        </form>\n      </Transition>\n    </Teleport>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nimport { ChevronLeft, Mail, Lock, Eye, EyeOff, Info } from 'lucide-vue-next'\nimport logoUrl from '~/assets/img/logo.svg'\n\nconst authStore = useAuthStore()\nconst metrics = ['планируйте', 'контролируйте', 'фокусируйтесь', 'управляйте']\nconst form = reactive({ email: '', password: '' })\nconst errors = reactive({ email: '', password: '' })\nconst showPassword = ref(false)\nconst showForgot = ref(false)\nconst forgotEmail = ref('')\nconst forgotError = ref('')\nconst resetSent = ref(false)\n\nfunction clearError(field: 'email' | 'password') {\n  errors[field] = ''\n}\n\nfunction validate() {\n  errors.email = ''\n  errors.password = ''\n\n  if (!form.email.trim() || !form.email.includes('@')) {\n    errors.email = 'Введите корректный email'\n  }\n\n  if (!form.password.trim()) {\n    errors.password = 'Введите пароль'\n  }\n\n  return !errors.email && !errors.password\n}\n\nfunction handleLogin() {\n  if (!validate()) return\n  authStore.login(form.email.trim(), form.password)\n}\n\nfunction loginWithGoogle() {\n  authStore.loginWithGoogle()\n}\n\nfunction sendReset() {\n  forgotError.value = ''\n\n  if (!forgotEmail.value.trim() || !forgotEmail.value.includes('@')) {\n    forgotError.value = 'Введите корректный email'\n    return\n  }\n\n  resetSent.value = true\n  setTimeout(() => {\n    closeForgotModal()\n  }, 2000)\n}\n\nfunction closeForgotModal() {\n  showForgot.value = false\n  resetSent.value = false\n  forgotError.value = ''\n}\n</script>\n"],"version":3}