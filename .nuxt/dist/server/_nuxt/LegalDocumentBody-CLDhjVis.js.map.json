{"file":"LegalDocumentBody-CLDhjVis.js","mappings":";;;;;;;;;AAaA,UAAM,QAAQ;AAOd,UAAM,SAAS,SAAS,MAAM;AAC5B,YAAM,SAAkB,CAAA;AACxB,iBAAW,WAAW,MAAM,QAAQ,MAAM,IAAI,GAAG;AAC/C,cAAM,OAAO,QAAQ,KAAA;AACrB,YAAI,CAAC,QAAQ,KAAK,WAAW,GAAG,EAAG;AACnC,YAAI,KAAK,WAAW,IAAI,GAAG;AACzB,iBAAO,KAAK,EAAE,MAAM,MAAM,MAAM,KAAK,MAAM,CAAC,EAAE,KAAA,EAAK,CAAG;AACtD;AAAA,QACF;AACA,YAAI,KAAK,WAAW,KAAK,GAAG;AAC1B,iBAAO,KAAK,EAAE,MAAM,MAAM,MAAM,KAAK,MAAM,CAAC,EAAE,KAAA,EAAK,CAAG;AACtD;AAAA,QACF;AACA,eAAO,KAAK,EAAE,MAAM,KAAK,MAAM,KAAK,QAAQ,SAAS,EAAE,GAAG;AAAA,MAC5D;AACA,aAAO;AAAA,IACT,CAAC;AAED,aAAS,WAAW,OAAc;AAChC,UAAI,MAAM,SAAS,MAAM;AACvB,eAAO;AAAA,MACT;AACA,UAAI,MAAM,SAAS,MAAM;AACvB,eAAO;AAAA,MACT;AACA,aAAO;AAAA,IACT;;AA7CO,YAAA,OAAAA,eAAAC,WAAA,EAAA,OAAM,0EAAsE,MAAA,CAAA,CAAA,WAAA;oBAEpDC,MAAA,MAAA,GAAM,CAAvB,OAAO,UAAK;2BAEZC,eAAA,WAAW,KAAK,CAAA,MAErBC,eAAA,MAAM,IAAI;;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_unref","_ssrRenderClass","_ssrInterpolate"],"sources":["../../../../components/LegalDocumentBody.vue"],"sourcesContent":["<template>\n  <div class=\"legal-document-body space-y-3 text-sm leading-relaxed text-sber-gray\">\n    <p\n      v-for=\"(block, index) in blocks\"\n      :key=\"index\"\n      :class=\"blockClass(block)\"\n    >\n      {{ block.text }}\n    </p>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nconst props = defineProps<{ content: string }>()\n\ninterface Block {\n  kind: 'h1' | 'h2' | 'p'\n  text: string\n}\n\nconst blocks = computed(() => {\n  const result: Block[] = []\n  for (const rawLine of props.content.split('\\n')) {\n    const line = rawLine.trim()\n    if (!line || line.startsWith('_')) continue\n    if (line.startsWith('# ')) {\n      result.push({ kind: 'h1', text: line.slice(2).trim() })\n      continue\n    }\n    if (line.startsWith('## ')) {\n      result.push({ kind: 'h2', text: line.slice(3).trim() })\n      continue\n    }\n    result.push({ kind: 'p', text: line.replace(/\\*\\*/g, '') })\n  }\n  return result\n})\n\nfunction blockClass(block: Block) {\n  if (block.kind === 'h1') {\n    return 'text-lg font-bold text-sber-black'\n  }\n  if (block.kind === 'h2') {\n    return 'pt-2 text-base font-semibold text-sber-black'\n  }\n  return 'whitespace-pre-wrap'\n}\n</script>\n"],"version":3}