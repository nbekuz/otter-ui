{"file":"faq-PbXGyqJt.js","mappings":";;;;;;;;;;;;;;;;;;;;AA8FA,UAAM,gBAAgB,iBAAA;AACJ,iBAAA;AAClB,UAAM,YAAY,IAAI,EAAE;AAWxB,UAAM,cAAc,SAAS,MAAM,cAAc,YAAY,UAAU,MAAM;AAE7E,UAAM,cAAc,SAAS,MAAM;AACjC,YAAM,QAAQ,cAAc;AAC5B,UAAI,CAAC,UAAU,MAAM,KAAA,EAAQ,QAAO;AACpC,YAAM,IAAI,UAAU,MAAM,KAAA,EAAO,YAAA;AACjC,aAAO,MAAM;AAAA,QAAO,CAAA,MAClB,EAAE,SAAS,YAAA,EAAc,SAAS,CAAC,KAChC,EAAE,OAAO,YAAA,EAAc,SAAS,CAAC;AAAA,MAAA;AAAA,IAExC,CAAC;;;QApHM,OAAK,CAAC,kBAAyBA,MAAA,WAAA,IAAW,iBAAA,oBAAA;AAAA,MAAA,2CAGnCA,MAAA,WAAA,IAAW,uDAAA,sBAAA,2BAAA,CAAA;AAQF,YAAAC,mBAAAD,MAAA,WAAA,GAAA,EAAA,OAAM,0BAAA,GAAyB,MAAA,OAAA,CAAA;;AAQtC,YAAAC,mBAAAD,MAAA,MAAA,GAAA,EAAA,OAAM,kEAAA,GAAiE,MAAA,OAAA,CAAA;4CAEpEA,MAAA,SAAA,CAAS,iHAQZA,MAAA,WAAA,IAAW,yCAAA,sBAAA,6BAAA,CAAA;AAEV,UAAAA,MAAA,aAAA,EAAc,gBAAc;;MAGvB,WAAAA,MAAA,aAAA,EAAc,cAAY;AACnC,cAAA,yDAAAE,eAAAF,MAAA,aAAA,EAAc,YAAY,CAAA,MAAA;AAAA;;;AAEpB,UAAAA,MAAA,aAAA,EAAc,cAAY;;MAMxB,WAAAA,MAAA,WAAA,EAAY,WAAM,GAAA;;;;AAObG,sBAAAH,MAAA,WAAA,IAAP,QAAG;AAMiD,gBAAA,+NAAAE,eAAA,IAAI,QAAQ,CAAA,SAAA;;YAEjE,OAAK,CAAC,oEACE,IAAI,OAAI,eAAA,EAAA;AAAA,UAAA;;AAMZ,cAAA,IAAI,MAAI;AAGX,kBAAA,+DAAAA,eAAA,IAAI,MAAM,CAAA,MAAA;AAAA;;;;;;;;;;;;;;;;;","names":["_unref","_ssrRenderComponent","_ssrInterpolate","_ssrRenderList"],"sources":["../../../../pages/app/faq.vue"],"sourcesContent":["<template>\n  <div class=\"page-container\" :class=\"isDarkTheme ? 'bg-[#0f1115]' : 'bg-sber-gray-light'\">\n    <div\n      class=\"page-header-top px-4 pb-4\"\n      :class=\"isDarkTheme ? 'bg-[#171a21] border-b border-[#2a303a] shadow-none' : 'bg-white shadow-sm'\"\n    >\n      <div class=\"flex items-center gap-3\">\n        <button\n          type=\"button\"\n          class=\"flex h-10 w-10 items-center justify-center rounded-full bg-sber-gray-light\"\n          @click=\"$router.back()\"\n        >\n          <ChevronLeft class=\"h-5 w-5 text-sber-black\" />\n        </button>\n        <h1 class=\"text-xl font-bold text-sber-black\">Частые вопросы</h1>\n      </div>\n    </div>\n\n    <div class=\"px-4 py-4\">\n      <div class=\"relative mb-4\">\n        <Search class=\"absolute left-4 top-1/2 h-4 w-4 -translate-y-1/2 text-sber-gray\" />\n        <input\n          v-model=\"faqSearch\"\n          placeholder=\"Поиск по вопросам...\"\n          class=\"input-field py-3 pl-11 text-sm\"\n        />\n      </div>\n\n      <div\n        class=\"rounded-2xl overflow-hidden\"\n        :class=\"isDarkTheme ? 'bg-[#171a21] border border-[#2a303a]' : 'bg-white shadow-sm'\"\n      >\n        <p v-if=\"settingsStore.helpFaqLoading\" class=\"py-10 text-center text-sm text-sber-gray\">\n          Загрузка…\n        </p>\n        <p v-else-if=\"settingsStore.helpFaqError\" class=\"px-4 py-6 text-center text-sm text-red-500\">\n          {{ settingsStore.helpFaqError }}\n        </p>\n        <div v-if=\"settingsStore.helpFaqError\" class=\"px-4 pb-4\">\n          <button class=\"btn-secondary w-full\" type=\"button\" @click=\"loadHelpFaq\">\n            Повторить\n          </button>\n        </div>\n        <p\n          v-else-if=\"filteredFaq.length === 0\"\n          class=\"py-10 text-center text-sm text-sber-gray\"\n        >\n          Вопросы не найдены\n        </p>\n        <div v-else>\n          <div\n            v-for=\"faq in filteredFaq\"\n            :key=\"faq.id\"\n            class=\"border-b border-sber-gray-light last:border-0\"\n          >\n            <button class=\"w-full px-4 text-left\" type=\"button\" @click=\"faq.open = !faq.open\">\n              <div class=\"flex items-start justify-between gap-2 py-4\">\n                <span class=\"text-sm font-semibold text-sber-black\">{{ faq.question }}</span>\n                <ChevronDown\n                  class=\"mt-0.5 h-4 w-4 flex-shrink-0 text-sber-gray transition-transform\"\n                  :class=\"faq.open ? 'rotate-180' : ''\"\n                />\n              </div>\n            </button>\n            <Transition name=\"slide-down\">\n              <p\n                v-if=\"faq.open\"\n                class=\"px-4 pb-4 text-sm leading-relaxed text-sber-gray\"\n              >\n                {{ faq.answer }}\n              </p>\n            </Transition>\n          </div>\n        </div>\n      </div>\n\n      <button\n        class=\"btn-primary mt-6\"\n        type=\"button\"\n        @click=\"goContact\"\n      >\n        Связаться с нами\n      </button>\n    </div>\n\n    <div class=\"h-8\" />\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nimport { ChevronDown, ChevronLeft, Search } from 'lucide-vue-next'\n\ndefinePageMeta({ layout: 'app' })\n\nconst settingsStore = useSettingsStore()\nconst authStore = useAuthStore()\nconst faqSearch = ref('')\n\nfunction goContact() {\n  if (authStore.isLoggedIn) {\n    navigateTo({ path: '/app/settings', query: { openContact: '1' } })\n  }\n  else {\n    navigateTo('/login')\n  }\n}\n\nconst isDarkTheme = computed(() => settingsStore.appSettings.theme === 'dark')\n\nconst filteredFaq = computed(() => {\n  const items = settingsStore.helpFaq\n  if (!faqSearch.value.trim()) return items\n  const q = faqSearch.value.trim().toLowerCase()\n  return items.filter(f =>\n    f.question.toLowerCase().includes(q)\n    || f.answer.toLowerCase().includes(q),\n  )\n})\n\nasync function loadHelpFaq() {\n  await settingsStore.fetchHelpFaq()\n}\n\nonMounted(() => {\n  if (!settingsStore.helpFaq.length && !settingsStore.helpFaqLoading) {\n    void loadHelpFaq()\n  }\n})\n</script>\n"],"version":3}