AM;AAAA,QACN,QAAQ;AAAA,QACR,KAAK;AAAA,QACL,MAAM;AAAA,MAAA;AAER,aAAO,OAAO,QAAQ,KAAK;AAAA,IAC7B;;AA7RO,YAAA,OAAAA,eAAAC,WAAA,EAAA,OAAM,qDAAiD,MAAA,CAAA,CAAA,wQAAA;AAM5C,YAAAC,mBAAAC,MAAA,QAAA,GAAA,EAAA,OAAM,0BAAA,GAAyB,MAAA,OAAA,CAAA;;AASpBC,oBAAAD,MAAA,aAAA,EAAc,SAAS,oBAA5B,MAAC;6CAEA,KAAKA,qBAAc,eAAeA,MAAA,aAAA,EAAc,SAAS,qBAAsBA,qBAAc,eAAY,KAAQA,MAAA,aAAA,EAAc,eAAeA,MAAA,aAAA,EAAc,SAAS,sBAAiB;;kXAe5L,UAAQA,MAAA,aAAA,EAAc,UAAO,YAAA,SAAA,0DAG7B,oBAAgB,GAAA,MAAWA,MAAA,aAAA,EAAc,QAAQ,MAAA,2BAC1C,EAAA,YAAA,6BAAA,CAA4C,0JAMUE,eAAAF,MAAA,aAAA,EAAc,WAAW;AAChF,UAAAA,MAAA,aAAA,EAAc,UAAK,UAAA;;MACd,WAAAA,MAAA,aAAA,EAAc,SAAO;;;AAE9B,cAAA,0CAAAE,eAAAF,MAAA,aAAA,EAAc,UAAK,YAAA,UAAA,OAAA,CAAA,MAAA;AAAA;AAUb,YAAA,0OAAAG,sBAAAH,MAAA,aAAA,EAAc,UAAK,MAAA,IAAA,cAAA,EAAA,GAAA;AAGtB,YAAAD,mBAAAC,MAAA,MAAA,GAAA,EAAA,OAAM,0BAAA,GAAyB,MAAA,OAAA,CAAA;AAM/B,YAAA,2BAAAI,eAAA,CAAAJ,MAAA,aAAA,EAAc,UAAK,YAAA,iBAAA,iBAAA,wGAAA,CAAA,CAAA,IAAA;AAGd,UAAAA,MAAA,aAAA,EAAc,UAAK,WAAA;AAAgB,cAAAD,mBAAAC,MAAA,KAAA,GAAA,EAAA,OAAM,qBAAA,GAAoB,MAAA,OAAA,CAAA;AAAA;AAC7D,cAAAD,mBAAAC,MAAA,IAAA,GAAA,EAAA,OAAM,0BAAA,GAAyB,MAAA,OAAA,CAAA;AAAA;;AAQ/B,YAAAD,mBAAAC,MAAA,WAAA,GAAA,EAAA,OAAM,0BAAA,GAAyB,MAAA,OAAA,CAAA;;AAY5C,YAAAD,mBAAAC,MAAA,MAAA,GAAA,EAAA,OAAM,0BAAA,GAAyB,MAAA,OAAA,CAAA;AAIhC,YAAA,gJAAAE,eAAAF,MAAA,YAAA,GAAc,SAAK,mBAAA,CAAA,YAAA;AAGZ,YAAAD,mBAAAC,MAAA,YAAA,GAAA,EAAA,OAAM,yBAAA,GAAwB,MAAA,OAAA,CAAA;;AAKrC,YAAAD,mBAAAC,MAAA,KAAA,GAAA,EAAA,OAAM,yBAAA,GAAwB,MAAA,OAAA,CAAA;;oBAIrBA,MAAA,gBAAA,EAAiB,MAAK,GAAA,CAAA,GAAA,CAA3B,MAAC;gDAGAA,MAAA,eAAA,MAAoB,EAAE,KAAE,6BAAA,qCAAA,gDAAA,CAAA,MAG7BE,eAAA,EAAE,IAAI;;;+BASjB,CAkCWG,WAAA;YAhCIL,MAAA,cAAA,GAAc;;;;;YAGdA,MAAA,cAAA,GAAc;2EAA8B,EAAA,cAAA,SAAA,cAAA,OAAA,CAA4C,CAAA,qGAAA;AAKvFK,iBAAAN,mBAAAC,MAAA,MAAA,GAAA,EAAA,OAAM,kEAAA,GAAiE,MAAA,OAAA,CAAA;iDAC/DA,MAAA,UAAA,CAAU,CAAA,2LAAA;AAQvBK,iBAAAN,mBAAAC,MAAA,CAAA,GAAA,EAAA,OAAM,UAAA,GAAS,MAAA,OAAA,CAAA;;AAGAC,wBAAAD,MAAA,aAAA,IAAR,SAAI;kCAGHI,eAAA,CAAAJ,MAAA,aAAA,EAAc,mBAAmB,KAAK,KAAE,wBAAA,0CAAA,+GAAA,CAAA,+FAGnB,iBAAiB,KAAK,QAAQ,EAAA,CAAA,2EACIE,eAAA,KAAK,KAAK;AAC/D,gBAAAF,MAAA,aAAA,EAAc,mBAAmB,KAAK,IAAE;AAAEK,qBAAAN,mBAAAC,MAAA,KAAA,GAAA,EAAA,OAAM,0BAAA,GAAyB,MAAA,OAAA,CAAA;AAAA;;;;;;;;;;+BAO9F,CA4EWK,WAAA;YA1EIL,MAAA,YAAA,GAAY;;;;;YAGZA,MAAA,YAAA,GAAY;+OAMAA,MAAA,aAAA,EAAc,SAAS,QAAQ,CAAA,yDAAA;AAG5BC,wBAAA,CAAA,IAAA,IAAA,IAAA,IAAA,IAAA,EAAA,IAAL,MAAC;qCAEAG,eAAA,CAAAJ,MAAA,aAAA,EAAc,SAAS,aAAa,oLAI/C,CAAC;;4JAQeA,MAAA,aAAA,EAAc,SAAS,UAAU,CAAA,+CAAA;AAGlCC,wBAAA,CAAA,GAAA,GAAA,GAAA,EAAA,IAAL,MAAC;qCAEAG,eAAA,CAAAJ,MAAA,aAAA,EAAc,SAAS,eAAe,kLAIjD,CAAC;;2TAaEA,MAAA,aAAA,EAAc,SAAS,mBAAgB,kBAAA,oBAAA,kDAAA,CAAA,kCAIlCA,MAAA,aAAA,EAAc,SAAS,mBAAgB,kBAAA,iBAAA,0EAAA,CAAA;AAQhCC,wBAAAD,MAAA,YAAA,IAAL,MAAC;qCAEAI,eAAA,CAAAJ,MAAA,aAAA,EAAc,SAAS,UAAU,EAAE,gMAI9CE,eAAA,EAAE,IAAI,KAAOA,eAAA,EAAE,IAAI;;;;;;;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_ssrRenderComponent","_unref","_ssrRenderList","_ssrInterpolate","_ssrIncludeBooleanAttr","_ssrRenderClass","_push"],"sources":["../../../../node_modules/nuxt/dist/app/compat/interval.js","../../../../stores/pomodoro.ts","../../../../pages/app/pomodoro.vue"],"sourcesContent":["import { createError } from \"../composables/error.js\";\nconst intervalError = \"[nuxt] `setInterval` should not be used on the server. Consider wrapping it with an `onNuxtReady`, `onBeforeMount` or `onMounted` lifecycle hook, or ensure you only call it in the browser by checking `import.meta.client`.\";\nexport const setInterval = import.meta.client ? globalThis.setInterval : (() => {\n  if (import.meta.dev) {\n    throw createError({\n      status: 500,\n      message: intervalError\n    });\n  }\n  console.error(intervalError);\n});\n","import { defineStore } from 'pinia'\nimport { defaultPomodoroSettings, type PomodoroSettings } from '~/data/mockData'\n\ntype TimerState = 'idle' | 'running' | 'paused' | 'break'\n\nexport const usePomodoroStore = defineStore('pomodoro', () => {\n  const settings = ref<PomodoroSettings>({ ...defaultPomodoroSettings })\n  const state = ref<TimerState>('idle')\n  const secondsLeft = ref(settings.value.duration * 60)\n  const selectedTaskId = ref<string | null>(null)\n  const sessionCount = ref(0)\n  const isBreak = ref(false)\n\n  let intervalId: ReturnType<typeof setInterval> | null = null\n\n  const totalSeconds = computed(() =>\n    isBreak.value\n      ? (sessionCount.value % settings.value.sessionsUntilLong === 0\n          ? settings.value.longBreak\n          : settings.value.shortBreak) * 60\n      : settings.value.duration * 60\n  )\n\n  const progress = computed(() =>\n    1 - secondsLeft.value / totalSeconds.value\n  )\n\n  const displayTime = computed(() => {\n    const m = Math.floor(secondsLeft.value / 60).toString().padStart(2, '0')\n    const s = (secondsLeft.value % 60).toString().padStart(2, '0')\n    return `${m}:${s}`\n  })\n\n  function start() {\n    if (state.value === 'idle' || state.value === 'paused') {\n      state.value = 'running'\n      intervalId = setInterval(() => {\n        if (secondsLeft.value > 0) {\n          secondsLeft.value--\n        } else {\n          // Timer finished\n          pause()\n          sessionCount.value++\n          state.value = 'idle'\n          secondsLeft.value = totalSeconds.value\n        }\n      }, 1000)\n    }\n  }\n\n  function pause() {\n    if (state.value === 'running') {\n      state.value = 'paused'\n      if (intervalId) {\n        clearInterval(intervalId)\n        intervalId = null\n      }\n    }\n  }\n\n  function stop() {\n    state.value = 'idle'\n    isBreak.value = false\n    if (intervalId) {\n      clearInterval(intervalId)\n      intervalId = null\n    }\n    secondsLeft.value = settings.value.duration * 60\n  }\n\n  function updateSettings(newSettings: Partial<PomodoroSettings>) {\n    settings.value = { ...settings.value, ...newSettings }\n    if (state.value === 'idle') {\n      secondsLeft.value = settings.value.duration * 60\n    }\n  }\n\n  function selectTask(taskId: string | null) {\n    selectedTaskId.value = taskId\n  }\n\n  return {\n    settings,\n    state,\n    secondsLeft,\n    totalSeconds,\n    progress,\n    displayTime,\n    selectedTaskId,\n    sessionCount,\n    isBreak,\n    start,\n    pause,\n    stop,\n    updateSettings,\n    selectTask,\n  }\n})\n","<template>\n  <div class=\"page-container flex flex-col bg-sber-gray-light\">\n    <!-- Header -->\n    <div class=\"flex items-center justify-between px-4 pt-14 pb-4 lg:px-6\">\n      <h1 class=\"text-xl font-bold text-sber-black\">Помодоро</h1>\n      <button class=\"flex h-9 w-9 items-center justify-center rounded-xl bg-white shadow-sm transition-colors active:bg-sber-gray-light\"\n              @click=\"settingsOpen = true\">\n        <Settings class=\"w-5 h-5 text-sber-black\" />\n      </button>\n    </div>\n\n    <div class=\"flex-1 px-4 pb-6 lg:px-6\">\n      <div class=\"mx-auto grid max-w-5xl gap-4 lg:grid-cols-[minmax(0,1.15fr)_minmax(320px,0.85fr)] lg:items-start\">\n        <div class=\"rounded-[32px] bg-white px-6 py-6 shadow-card\">\n          <!-- Session count -->\n          <div class=\"mb-6 flex justify-center gap-2\">\n            <div v-for=\"i in pomodoroStore.settings.sessionsUntilLong\" :key=\"i\"\n                 class=\"h-2 w-8 rounded-full transition-colors\"\n                 :class=\"i <= pomodoroStore.sessionCount % pomodoroStore.settings.sessionsUntilLong || (pomodoroStore.sessionCount > 0 && pomodoroStore.sessionCount % pomodoroStore.settings.sessionsUntilLong === 0)\n                  ? 'bg-sber-green'\n                  : 'bg-sber-gray-mid'\" />\n          </div>\n\n          <!-- Timer circle -->\n          <div class=\"flex flex-col items-center justify-center\">\n            <div class=\"relative mb-8 h-64 w-64 rounded-full bg-sber-gray-light\">\n              <!-- SVG ring -->\n              <svg class=\"h-full w-full -rotate-90\" viewBox=\"0 0 100 100\">\n                <!-- Background ring -->\n                <circle cx=\"50\" cy=\"50\" r=\"45\" fill=\"none\" stroke=\"rgba(142,142,147,0.18)\" stroke-width=\"6\" />\n                <!-- Progress ring -->\n                <circle\n                  cx=\"50\" cy=\"50\" r=\"45\" fill=\"none\"\n                  :stroke=\"pomodoroStore.isBreak ? '#007AFF' : '#21A038'\"\n                  stroke-width=\"6\"\n                  stroke-linecap=\"round\"\n                  :stroke-dasharray=\"`${283 * pomodoroStore.progress} 283`\"\n                  :style=\"{ transition: 'stroke-dasharray 1s linear' }\"\n                />\n              </svg>\n\n              <!-- Time display -->\n              <div class=\"absolute inset-0 flex flex-col items-center justify-center\">\n                <p class=\"text-5xl font-bold tracking-tight text-sber-black\">{{ pomodoroStore.displayTime }}</p>\n                <p v-if=\"pomodoroStore.state === 'paused'\" class=\"mt-1 text-sm text-sber-gray\">На паузе</p>\n                <p v-else-if=\"pomodoroStore.isBreak\" class=\"mt-1 text-sm text-sber-blue\">Перерыв</p>\n                <p v-else class=\"mt-1 text-sm text-sber-gray\">\n                  {{ pomodoroStore.state === 'running' ? 'Фокус' : 'Готов' }}\n                </p>\n              </div>\n            </div>\n\n            <!-- Controls -->\n            <div class=\"flex items-center gap-6\">\n              <!-- Stop -->\n              <button\n                class=\"flex h-12 w-12 items-center justify-center rounded-full border border-sber-gray-light bg-sber-gray-light transition-colors active:bg-sber-gray-mid disabled:opacity-50\"\n                :disabled=\"pomodoroStore.state === 'idle'\"\n                @click=\"pomodoroStore.stop()\"\n              >\n                <Square class=\"h-5 w-5 text-sber-black\" />\n              </button>\n\n              <!-- Play/Pause (main) -->\n              <button\n                class=\"flex h-20 w-20 items-center justify-center rounded-full shadow-lg transition-transform active:scale-95\"\n                :class=\"pomodoroStore.state === 'running' ? 'bg-sber-blue' : 'bg-sber-green'\"\n                @click=\"toggleTimer\"\n              >\n                <Pause v-if=\"pomodoroStore.state === 'running'\" class=\"h-8 w-8 text-white\" />\n                <Play v-else class=\"ml-1 h-8 w-8 text-white\" />\n              </button>\n\n              <!-- Skip -->\n              <button\n                class=\"flex h-12 w-12 items-center justify-center rounded-full border border-sber-gray-light bg-sber-gray-light transition-colors active:bg-sber-gray-mid\"\n                @click=\"pomodoroStore.stop()\"\n              >\n                <SkipForward class=\"h-5 w-5 text-sber-black\" />\n              </button>\n            </div>\n          </div>\n        </div>\n\n        <!-- Focus Task -->\n        <div class=\"space-y-3\">\n      <button\n        class=\"flex w-full items-center gap-3 rounded-[28px] border border-sber-gray-light bg-white px-4 py-4 shadow-sm transition-colors active:bg-sber-gray-light\"\n        @click=\"taskPickerOpen = true\"\n      >\n        <Target class=\"w-5 h-5 text-sber-green\" />\n        <div class=\"flex-1 text-left\">\n          <p class=\"text-xs text-sber-gray\">Задача для фокуса</p>\n          <p class=\"text-sm font-medium text-sber-black truncate\">\n            {{ selectedTask?.title || 'Выбрать задачу...' }}\n          </p>\n        </div>\n        <ChevronRight class=\"w-4 h-4 text-sber-gray\" />\n      </button>\n\n      <!-- Work sound -->\n      <div class=\"flex items-center gap-3 rounded-[28px] border border-sber-gray-light bg-white px-4 py-4 shadow-sm\">\n        <Music class=\"w-5 h-5 text-sber-gray\" />\n        <span class=\"text-sm text-sber-gray flex-1\">Звук фоновый</span>\n        <div class=\"flex gap-2 flex-wrap justify-end\">\n          <button\n            v-for=\"s in workSoundOptions.slice(0, 4)\"\n            :key=\"s.id\"\n            class=\"text-sm px-2 py-1 rounded-lg transition-colors\"\n            :class=\"activeWorkSound === s.id ? 'bg-sber-green text-white' : 'bg-sber-gray-light text-sber-gray'\"\n            @click=\"activeWorkSound = s.id\"\n          >\n            {{ s.icon }}\n          </button>\n        </div>\n      </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- Task picker modal -->\n    <Teleport to=\"body\">\n      <Transition name=\"overlay\">\n        <div v-if=\"taskPickerOpen\" class=\"overlay\" @click=\"taskPickerOpen = false\" />\n      </Transition>\n      <Transition name=\"modal\">\n        <div v-if=\"taskPickerOpen\" class=\"app-modal px-4 py-5\" style=\"max-height: 75dvh; overflow-y: auto;\" @click.stop>\n          <h3 class=\"text-lg font-bold text-sber-black mb-3\">Выбрать задачу</h3>\n\n          <!-- Search -->\n          <div class=\"relative mb-4\">\n            <Search class=\"absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-sber-gray\" />\n            <input v-model=\"taskSearch\" placeholder=\"Поиск...\" class=\"input-field pl-11 py-3 text-sm\" />\n          </div>\n\n          <button\n            class=\"w-full flex items-center gap-3 px-4 py-3 rounded-2xl mb-2\n                   bg-sber-gray-light text-sber-gray text-sm\"\n            @click=\"selectTask(null)\"\n          >\n            <X class=\"w-4 h-4\" /> Без задачи\n          </button>\n\n          <div v-for=\"task in filteredTasks\" :key=\"task.id\"\n               class=\"flex items-center gap-3 px-4 py-3 rounded-2xl mb-2 cursor-pointer\n                      transition-colors active:bg-sber-gray-light\"\n               :class=\"pomodoroStore.selectedTaskId === task.id ? 'bg-sber-green-light' : 'bg-white border border-sber-gray-light'\"\n               @click=\"selectTask(task.id)\">\n            <div class=\"w-3 h-3 rounded-full flex-shrink-0\"\n                 :style=\"{ backgroundColor: getPriorityColor(task.priority) }\" />\n            <p class=\"text-sm text-sber-black font-medium flex-1 truncate\">{{ task.title }}</p>\n            <Check v-if=\"pomodoroStore.selectedTaskId === task.id\" class=\"w-4 h-4 text-sber-green\" />\n          </div>\n        </div>\n      </Transition>\n    </Teleport>\n\n    <!-- Settings modal -->\n    <Teleport to=\"body\">\n      <Transition name=\"overlay\">\n        <div v-if=\"settingsOpen\" class=\"overlay\" @click=\"settingsOpen = false\" />\n      </Transition>\n      <Transition name=\"modal\">\n        <div v-if=\"settingsOpen\" class=\"app-modal px-5 py-5\" @click.stop>\n          <h3 class=\"text-lg font-bold text-sber-black mb-5\">Настройки Помодоро</h3>\n\n          <!-- Duration -->\n          <div class=\"mb-5\">\n            <label class=\"text-sm font-semibold text-sber-black mb-3 block\">\n              Длительность: {{ pomodoroStore.settings.duration }} мин\n            </label>\n            <div class=\"flex gap-2 flex-wrap\">\n              <button v-for=\"d in [15, 20, 25, 30, 45, 60]\" :key=\"d\"\n                      class=\"px-4 py-2 rounded-xl text-sm font-medium border transition-colors\"\n                      :class=\"pomodoroStore.settings.duration === d\n                        ? 'bg-sber-green text-white border-sber-green'\n                        : 'border-sber-gray-mid text-sber-black'\"\n                      @click=\"pomodoroStore.updateSettings({ duration: d })\">\n                {{ d }} мин\n              </button>\n            </div>\n          </div>\n\n          <!-- Short break -->\n          <div class=\"mb-5\">\n            <label class=\"text-sm font-semibold text-sber-black mb-3 block\">\n              Короткий перерыв: {{ pomodoroStore.settings.shortBreak }} мин\n            </label>\n            <div class=\"flex gap-2\">\n              <button v-for=\"d in [3, 5, 7, 10]\" :key=\"d\"\n                      class=\"px-4 py-2 rounded-xl text-sm font-medium border transition-colors\"\n                      :class=\"pomodoroStore.settings.shortBreak === d\n                        ? 'bg-sber-blue text-white border-sber-blue'\n                        : 'border-sber-gray-mid text-sber-black'\"\n                      @click=\"pomodoroStore.updateSettings({ shortBreak: d })\">\n                {{ d }} мин\n              </button>\n            </div>\n          </div>\n\n          <!-- Show on lock screen -->\n          <div class=\"flex items-center justify-between py-3 border-b border-sber-gray-light mb-5\">\n            <div>\n              <p class=\"text-sm font-medium text-sber-black\">Показывать при блокировке</p>\n              <p class=\"text-xs text-sber-gray\">На экране блокировки смартфона</p>\n            </div>\n            <button\n              class=\"w-12 h-6 rounded-full transition-colors relative\"\n              :class=\"pomodoroStore.settings.showOnLockScreen ? 'bg-sber-green' : 'bg-sber-gray-mid'\"\n              @click=\"pomodoroStore.updateSettings({ showOnLockScreen: !pomodoroStore.settings.showOnLockScreen })\"\n            >\n              <div class=\"absolute top-1 w-4 h-4 bg-white rounded-full shadow transition-transform\"\n                   :class=\"pomodoroStore.settings.showOnLockScreen ? 'translate-x-7' : 'translate-x-1'\" />\n            </button>\n          </div>\n\n          <!-- Completion sound -->\n          <div class=\"mb-5\">\n            <label class=\"text-sm font-semibold text-sber-black mb-3 block\">Звук завершения</label>\n            <div class=\"flex gap-2 flex-wrap\">\n              <button v-for=\"s in soundOptions\" :key=\"s.id\"\n                      class=\"flex items-center gap-1.5 px-3 py-2 rounded-xl text-xs font-medium border transition-colors\"\n                      :class=\"pomodoroStore.settings.sound === s.id\n                        ? 'bg-sber-green text-white border-sber-green'\n                        : 'border-sber-gray-mid text-sber-black'\"\n                      @click=\"pomodoroStore.updateSettings({ sound: s.id })\">\n                {{ s.icon }} {{ s.name }}\n              </button>\n            </div>\n          </div>\n\n          <button class=\"btn-primary\" @click=\"settingsOpen = false\">Готово</button>\n        </div>\n      </Transition>\n    </Teleport>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nimport {\n  Settings, Play, Pause, Square, SkipForward,\n  Target, Music, Search, Check, X, ChevronRight\n} from 'lucide-vue-next'\nimport { soundOptions, workSoundOptions } from '~/data/mockData'\n\ndefinePageMeta({ layout: 'app' })\n\nconst pomodoroStore = usePomodoroStore()\nconst tasksStore = useTasksStore()\n\nconst settingsOpen = ref(false)\nconst taskPickerOpen = ref(false)\nconst taskSearch = ref('')\nconst activeWorkSound = ref('rain')\n\nconst selectedTask = computed(() =>\n  tasksStore.tasks.find(t => t.id === pomodoroStore.selectedTaskId)\n)\n\nconst filteredTasks = computed(() => {\n  const activeTasks = tasksStore.tasks.filter(t => !t.completed)\n  if (!taskSearch.value) return activeTasks\n  return activeTasks.filter(t => t.title.toLowerCase().includes(taskSearch.value.toLowerCase()))\n})\n\nfunction toggleTimer() {\n  if (pomodoroStore.state === 'running') {\n    pomodoroStore.pause()\n  } else {\n    pomodoroStore.start()\n  }\n}\n\nfunction selectTask(taskId: string | null) {\n  pomodoroStore.selectTask(taskId)\n  taskPickerOpen.value = false\n}\n\nfunction getPriorityColor(priority: string) {\n  const colors: Record<string, string> = {\n    high: '#FF3B30',\n    medium: '#FF9500',\n    low: '#34C759',\n    none: '#8E8E93',\n  }\n  return colors[priority] || '#8E8E93'\n}\n</script>\n"],"version":3}