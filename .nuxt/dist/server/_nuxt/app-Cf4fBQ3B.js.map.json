,MAC9D,EAAE,IAAI,UAAU,IAAI,eAAe,MAAM,SAAS,OAAO,UAAA;AAAA,MACzD,EAAE,IAAI,YAAY,IAAI,iBAAiB,MAAM,OAAO,OAAO,WAAA;AAAA,MAC3D,EAAE,IAAI,YAAY,IAAI,iBAAiB,MAAM,UAAU,OAAO,YAAA;AAAA,IAAY;AAG5E,aAAS,SAAS,IAAY;AAC5B,UAAI,OAAO,OAAQ,QAAO,MAAM,SAAS;AACzC,aAAO,MAAM,KAAK,WAAW,EAAE;AAAA,IACjC;;;;;;QAxGO,OAAK,CAAC,6BAAoCA,MAAA,WAAA,IAAW,iBAAA,oBAAA;AAAA,MAAA,uKAI5CA,MAAA,WAAA,IAAW,gEAAA,8BAAA,wFAAA,CAAA;;QAGN,MAAK;AAAA,QAAK,kBAAe;AAAA,QAAM,cAAYA,MAAA,WAAA,IAAW,eAAA;AAAA,MAAA;;;QAQjE,IAAG;AAAA,QACH,OAAK,CAAC,mDACEA,MAAA,WAAA,IAAW,4DAAA,uCAAA;AAAA,MAAA;yBAHrB,CAqBW,GAAAC,QAAAC,UAAA,aAAA;;;iBAbQF,MAAA,SAAA,EAAU,MAAM,QAAM;yCAAKM,eAAAN,MAAA,SAAA,EAAU,MAAM,WAAW,YAAA,KAAW,GAAA;;4BACjES,cAAA,OAAKT,MAAA,SAAA,EAAU,KAAK,MAAM;;gMAIwBA,MAAA,SAAA,EAAU,MAAM,QAAI,cAAA;gBACrEA,MAAA,SAAA,EAAU,MAAM,WAAS;;;;;iGAIOA,MAAA,SAAA,EAAU,MAAM,SAAK,gBAAA;;;cAbvEI,YAAmF,KAAA,EAAhF,OAAM,+DAAA,GAA+D,SAAO;AAAA,cAC/EA,YAcM,OAAA,EAdD,OAAM,kCAA8B;AAAA,gBACvCA,YAGM,OAAA,EAHD,OAAM,yHAAqH;AAAA,mBACjHJ,MAAA,SAAA,EAAU,MAAM,UAA7BU,UAAA,GAAAH,YAAiG,oCAAzDP,MAAA,SAAA,EAAU,MAAM,WAAW,YAAA,KAAW,GAAA,GAAA,CAAA,mBAC9EO,YAA8E,OAAA;AAAA;oBAAjE,KAAKP,MAAA,SAAA,EAAU,KAAK;AAAA,oBAAQ,OAAM;AAAA,kBAAA;;gBAEjDI,YAQM,OAAA,EARD,OAAM,aAAS;AAAA,kBAClBA,YAKM,OAAA,EALD,OAAM,6BAAyB;AAAA,oBAClCA,YAA0G,KAAA,EAAvG,OAAM,oEAAoDJ,MAAA,SAAA,EAAU,MAAM,QAAI,cAAA,GAAA,CAAA;AAAA,oBACrEA,MAAA,SAAA,EAAU,MAAM,0BAA5BO,YAEO,QAAA;AAAA;sBAFgC,OAAM;AAAA,oBAAA,GAAuG,OAEpJ;;kBAEFH,YAA8F,KAAA,EAA3F,OAAM,qDAAqCJ,MAAA,SAAA,EAAU,MAAM,SAAK,gBAAA,GAAA,CAAA;AAAA,gBAAA;;;;;;;2CAO/DA,MAAA,WAAA,IAAW,yCAAA,kBAAA,+CAAA,CAAA,CAAA,YAAA;AAGFD,oBAAA,WAAR,SAAI;;UACV,KAAK,KAAK;AAAA,UACV,IAAI,KAAK;AAAA,UACV,QAAM,uFACE,SAAS,KAAK,EAAE,2CAAuEC,MAAA,WAAA;;2BALjG,CAaW,GAAAC,QAAAC,UAAA,aAAA;;AAFOC,6BAAAF,QAAAG,YAAAC,wBAAA,KAAK,IAAI,GAAA,EAAE,OAAM,UAAA,GAAS,IAAA,GAAAH,UAAA,QAAA;yCACjCI,eAAA,KAAK,KAAK;;;iBADnBI,UAAA,GAAAH,YAA6CF,wBAA7B,KAAK,IAAI,GAAA,EAAE,OAAM,WAAS;AAAA,gBAC1CD,YAA6B,QAAA,MAAAI,gBAApB,KAAK,KAAK,GAAA,CAAA;AAAA,cAAA;AAAA;;;;;;AAKf,YAAAG,mBAAAX,MAAA,IAAA,GAAA,EAAA,OAAM,UAAA,GAAS,MAAA,OAAA,CAAA;0EAOfA,MAAA,WAAA,IAAW,+CAAA,sFAAA,qEAAA,CAAA,CAAA,mEAAA;;;;;AAYX,YAAAW,mBAAAX,MAAA,IAAA,GAAA,EAAA,OAAM,qBAAA,GAAoB,MAAA,OAAA,CAAA;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_ssrRenderList","_unref","_push","_parent","_ssrRenderVNode","_createVNode","_resolveDynamicComponent","_ssrInterpolate","_createBlock","_toDisplayString","_ssrRenderAttr","_openBlock","_ssrRenderComponent"],"sources":["../../../../components/layout/BottomNav.vue","../../../../layouts/app.vue"],"sourcesContent":["<template>\n  <nav class=\"fixed bottom-0 left-1/2 z-40 w-full max-w-[430px] -translate-x-1/2 border-t border-sber-gray-mid bg-white safe-bottom lg:hidden\">\n    <div class=\"flex items-center justify-around px-2 py-2\">\n      <NuxtLink\n        v-for=\"item in navItems\"\n        :key=\"item.id\"\n        :to=\"item.to\"\n        class=\"flex flex-col items-center gap-1 min-w-[52px] py-1 px-2 rounded-xl\n               transition-colors active:bg-sber-gray-light relative\"\n        :class=\"isActive(item.to) ? 'text-sber-green' : 'text-sber-gray'\"\n      >\n        <component :is=\"item.icon\" class=\"w-6 h-6\" :stroke-width=\"isActive(item.to) ? 2.5 : 1.8\" />\n        <span class=\"text-[10px] font-medium leading-none\">{{ item.label }}</span>\n        <!-- Today's date badge on calendar -->\n        <span v-if=\"item.id === 'calendar' && !isActive(item.to)\"\n              class=\"absolute top-0.5 right-0.5 text-[8px] font-bold text-sber-gray\n                     bg-sber-gray-light rounded px-0.5\">\n          {{ todayDate }}\n        </span>\n        <span v-if=\"item.id === 'calendar' && isActive(item.to)\"\n              class=\"absolute top-0.5 right-0.5 text-[8px] font-bold text-sber-green\n                     bg-sber-green-light rounded px-0.5\">\n          {{ todayDate }}\n        </span>\n      </NuxtLink>\n    </div>\n  </nav>\n</template>\n\n<script setup lang=\"ts\">\nimport { CheckSquare, Calendar, Grid2x2, Timer, Settings } from 'lucide-vue-next'\nimport dayjs from 'dayjs'\n\nconst route = useRoute()\nconst settingsStore = useSettingsStore()\nconst todayDate = dayjs().format('D')\n\nconst allNavItems = [\n  { id: 'tasks', to: '/app', icon: CheckSquare, label: 'Задачи' },\n  { id: 'calendar', to: '/app/calendar', icon: Calendar, label: 'Календарь' },\n  { id: 'matrix', to: '/app/matrix', icon: Grid2x2, label: 'Матрица' },\n  { id: 'pomodoro', to: '/app/pomodoro', icon: Timer, label: 'Помодоро' },\n  { id: 'settings', to: '/app/settings', icon: Settings, label: 'Настройки' },\n]\n\nconst navItems = computed(() => {\n  const order = settingsStore.appSettings.bottomNavItems || []\n  const byId = new Map(allNavItems.map(item => [item.id, item]))\n  return order.map(id => byId.get(id)).filter(Boolean) as typeof allNavItems\n})\n\nfunction isActive(to: string) {\n  if (to === '/app') return route.path === '/app'\n  return route.path.startsWith(to)\n}\n</script>\n","<template>\n  <div class=\"min-h-dvh lg:px-6 lg:py-6\" :class=\"isDarkTheme ? 'bg-[#0f1115]' : 'bg-sber-gray-light'\">\n    <div class=\"mx-auto flex min-h-dvh max-w-[1440px] lg:h-[calc(100dvh-3rem)] lg:min-h-[calc(100dvh-3rem)] lg:gap-6 rounded\">\n      <aside\n        class=\"hidden lg:flex lg:h-full lg:w-72 lg:flex-shrink-0 lg:flex-col lg:rounded-[32px] lg:p-6\"\n        :class=\"isDarkTheme ? 'lg:bg-[#171a21] lg:text-white lg:border lg:border-[#2a303a]' : 'lg:bg-white lg:shadow-card'\"\n      >\n        <div class=\"mb-2\">\n          <BrandLogo size=\"md\" show-name-from=\"md\" :text-class=\"isDarkTheme ? 'text-white' : 'text-sber-black'\" />\n          <!-- <h2 class=\"mt-2 text-3xl font-bold text-sber-black\">Рабочее пространство</h2>\n          <p class=\"mt-2 text-sm leading-relaxed text-sber-gray\">\n            Все основные разделы всегда под рукой и удобно выглядят на широком экране.\n          </p> -->\n        </div>\n\n        <NuxtLink\n          to=\"/app/profile\"\n          class=\"mb-6 block rounded-[28px] p-4 transition-colors\"\n          :class=\"isDarkTheme ? 'bg-[#10141b] border border-[#2a303a] hover:bg-[#1b212b]' : 'bg-sber-gray-light hover:bg-[#ececef]'\"\n        >\n          <p class=\"text-xs font-semibold uppercase tracking-wide text-sber-gray\">Профиль</p>\n          <div class=\"mt-4 flex items-center gap-3\">\n            <div class=\"flex h-12 w-12 items-center justify-center overflow-hidden rounded-2xl bg-sber-green text-base font-bold text-white\">\n              <span v-if=\"!authStore.user?.avatar\">{{ authStore.user?.name?.[0]?.toUpperCase() || 'A' }}</span>\n              <img v-else :src=\"authStore.user.avatar\" class=\"h-full w-full object-cover\" />\n            </div>\n            <div class=\"min-w-0\">\n              <div class=\"flex items-center gap-2\">\n                <p class=\"truncate text-sm font-semibold text-sber-black\">{{ authStore.user?.name || 'Пользователь' }}</p>\n                <span v-if=\"authStore.user?.isPremium\" class=\"rounded-full bg-yellow-100 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide text-yellow-700\">\n                  Pro\n                </span>\n              </div>\n              <p class=\"truncate text-xs text-sber-gray\">{{ authStore.user?.email || 'demo@otter.app' }}</p>\n            </div>\n          </div>\n        </NuxtLink>\n\n        <nav\n          class=\"flex flex-1 flex-col gap-2 rounded-[28px] p-2\"\n          :class=\"isDarkTheme ? 'bg-[#10141b] border border-[#222833]' : 'bg-transparent'\"\n        >\n          <NuxtLink\n            v-for=\"item in navItems\"\n            :key=\"item.id\"\n            :to=\"item.to\"\n            class=\"flex items-center gap-3 rounded-2xl px-4 py-3 text-sm font-medium transition-colors\"\n            :class=\"isActive(item.to)\n              ? 'bg-sber-green text-white shadow-sm'\n              : isDarkTheme\n                ? 'text-slate-300 hover:bg-[#20242d] hover:text-white'\n                : 'text-sber-gray hover:bg-sber-gray-light hover:text-sber-black'\"\n          >\n            <component :is=\"item.icon\" class=\"h-5 w-5\" />\n            <span>{{ item.label }}</span>\n          </NuxtLink>\n        </nav>\n\n        <button class=\"mt-6 flex items-center justify-center gap-2 rounded-2xl bg-sber-green px-4 py-4 text-base font-semibold text-white transition-colors hover:bg-sber-green-dark\" @click=\"openNewTask\">\n          <Plus class=\"h-5 w-5\" />\n          Новая задача\n        </button>\n      </aside>\n\n      <div\n        class=\"phone-frame relative flex-1 lg:h-[calc(100dvh-3rem)]  lg:rounded-3xl\"\n        :class=\"isDarkTheme ? 'bg-[#0f1115] lg:border lg:border-[#2a303a]' : 'bg-white lg:border lg:border-[#e9ebf1] lg:shadow-[0_20px_48px_rgba(15,23,42,0.10)]'\"\n      >\n        <div class=\"min-h-dvh lg:h-full lg:min-h-0 lg:overflow-y-auto \">\n          <slot />\n        </div>\n\n        <LayoutBottomNav />\n\n        <button\n          class=\"fixed bottom-24 right-4 z-30 flex h-14 w-14 items-center justify-center rounded-full bg-sber-green shadow-lg transition-transform active:scale-95 lg:hidden\"\n          @click=\"openNewTask\"\n        >\n          <Plus class=\"h-7 w-7 text-white\" />\n        </button>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nimport { Calendar, CheckSquare, Grid2x2, Plus, Settings, Timer } from 'lucide-vue-next'\n\nconst route = useRoute()\nconst authStore = useAuthStore()\nconst settingsStore = useSettingsStore()\nconst isDarkTheme = computed(() => settingsStore.appSettings.theme === 'dark')\nconst isTasksPage = computed(() => route.path === '/app')\n\nconst navItems = [\n  { id: 'tasks', to: '/app', icon: CheckSquare, label: 'Задачи' },\n  { id: 'calendar', to: '/app/calendar', icon: Calendar, label: 'Календарь' },\n  { id: 'matrix', to: '/app/matrix', icon: Grid2x2, label: 'Матрица' },\n  { id: 'pomodoro', to: '/app/pomodoro', icon: Timer, label: 'Помодоро' },\n  { id: 'settings', to: '/app/settings', icon: Settings, label: 'Настройки' },\n]\n\nfunction isActive(to: string) {\n  if (to === '/app') return route.path === '/app'\n  return route.path.startsWith(to)\n}\n\nfunction openNewTask() {\n  navigateTo(`/app/new-task?returnTo=${encodeURIComponent(route.fullPath)}`)\n}\n</script>\n"],"version":3}